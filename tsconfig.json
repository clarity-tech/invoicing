{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "preserve",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,
        "noEmit": true,
        "paths": {
            "@/*": ["./resources/ts/*"]
        },
        "types": ["node", "vite/client"]
    },
    "include": ["resources/ts/**/*.ts", "resources/ts/**/*.vue"],
    "exclude": ["node_modules"]
}
