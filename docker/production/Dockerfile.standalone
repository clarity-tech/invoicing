# Laravel Application as Standalone Binary with FrankenPHP
# Optimized: separate PHP deps, frontend build (bun), clean app assembly

# ========================================
# Stage 1: PHP Dependencies
# ========================================
FROM serversideup/php:8.5-cli AS php-deps

USER root
WORKDIR /var/www/html

COPY composer.json composer.lock ./

RUN composer install \
    --no-dev \
    --no-interaction \
    --no-progress \
    --no-ansi \
    --no-scripts \
    --optimize-autoloader \
    --classmap-authoritative

# ========================================
# Stage 2: Frontend Build (bun, no Node.js)
# ========================================
FROM oven/bun:1.2-slim AS frontend

WORKDIR /build

COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

# Copy only what Tailwind @source + Vite needs
COPY resources/ resources/
COPY vite.config.js postcss.config.js tailwind.config.js ./

# Vendor blade files for Tailwind class scanning (referenced in app.css @source)
COPY --from=php-deps /var/www/html/vendor/laravel/framework/src/Illuminate/Pagination/resources/views/ \
    vendor/laravel/framework/src/Illuminate/Pagination/resources/views/

RUN mkdir -p storage/framework/views

ARG VITE_APP_NAME="Clarity Invoicing"
RUN bun run build

# ========================================
# Stage 3: Clean Application Assembly
# ========================================
FROM serversideup/php:8.5-cli AS app

USER root
WORKDIR /var/www/html

COPY . .
COPY --from=php-deps /var/www/html/vendor vendor/
COPY --from=frontend /build/public/build public/build/

# Remove non-runtime files
RUN rm -rf node_modules tests docker .git .github .agents .claude .gemini \
    docs *.md phpunit.xml phpunit.dusk.xml bun.lock package.json boost.json \
    .env .env.* .editorconfig .gitignore .gitattributes .gitmodules \
    .mcp.json postcss.config.js tailwind.config.js vite.config.js \
    resources/css resources/js

# ========================================
# Static Binary Build Stage
# ========================================
FROM dunglas/frankenphp:static-builder AS static-builder

# Copy clean application from app stage
COPY --from=app /var/www/html /go/src/app/dist

# Build the static binary with embedded application
RUN cd /go/src/app && \
    EMBED=dist/ CGO_ENABLED=1 go build \
        -buildmode=pie \
        -tags "cgo,netgo,osusergo,static_build" \
        -ldflags "-linkmode=external -extldflags -static-pie -s -w" \
        -o frankenphp-app

# ========================================
# Runtime Stage - Minimal Debian
# ========================================
FROM debian:12-slim AS runtime

# Install minimal runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd -g 1000 www \
    && useradd -u 1000 -g www -m -s /bin/bash www

# Set production environment variables
ENV APP_ENV=production
ENV APP_DEBUG=false
ENV APP_TIMEZONE=UTC
ENV LOG_CHANNEL=stderr

# Laravel storage path for consistent file storage (per FrankenPHP docs)
ENV LARAVEL_STORAGE_PATH=/app/storage

# Copy the static binary from builder
COPY --from=static-builder /go/src/app/frankenphp-app /usr/local/bin/frankenphp-app

# Set working directory
WORKDIR /app

# Create necessary directories
RUN mkdir -p /app/storage/logs /app/storage/framework/cache \
    /app/storage/framework/sessions /app/storage/framework/views \
    /app/bootstrap/cache \
    && chown -R www:www /app \
    && chmod +x /usr/local/bin/frankenphp-app

# Switch to non-root user for security
USER www

# Expose port
EXPOSE 8000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8000/up || exit 1

# Run the standalone binary
CMD ["/usr/local/bin/frankenphp-app", "php-server", "--listen", "0.0.0.0:8000"]

# ========================================
# Alternative: Standalone with Alpine
# ========================================
FROM alpine:3.19 AS standalone-alpine

# Install minimal runtime dependencies (curl needed for health check)
RUN apk add --no-cache \
    ca-certificates \
    curl \
    tzdata \
    && addgroup -g 1000 www \
    && adduser -u 1000 -G www -s /bin/sh -D www

# Set production environment variables
ENV APP_ENV=production
ENV APP_DEBUG=false
ENV APP_TIMEZONE=UTC
ENV LOG_CHANNEL=stderr
ENV LARAVEL_STORAGE_PATH=/app/storage

# Copy the static binary from builder
COPY --from=static-builder /go/src/app/frankenphp-app /usr/local/bin/frankenphp-app

# Set working directory and create necessary directories
WORKDIR /app
RUN mkdir -p /app/storage/logs /app/storage/framework/cache \
    /app/storage/framework/sessions /app/storage/framework/views \
    /app/bootstrap/cache \
    && chown -R www:www /app

# Switch to non-root user
USER www

# Expose port
EXPOSE 8000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8000/up || exit 1

# Run the standalone binary
CMD ["/usr/local/bin/frankenphp-app", "php-server", "--listen", "0.0.0.0:8000"]
