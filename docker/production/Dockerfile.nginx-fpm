# Production Dockerfile with ServerSideUp FPM + Nginx
# Optimized: separate PHP deps, frontend build (bun), clean app assembly

# ========================================
# Stage 1: PHP Dependencies
# ========================================
FROM serversideup/php:8.5-cli AS php-deps

USER root
WORKDIR /var/www/html

COPY composer.json composer.lock ./

RUN composer install \
    --no-dev \
    --no-interaction \
    --no-progress \
    --no-ansi \
    --no-scripts \
    --optimize-autoloader \
    --classmap-authoritative

# ========================================
# Stage 2: Frontend Build (bun, no Node.js)
# ========================================
FROM oven/bun:1.2-slim AS frontend

WORKDIR /build

COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

# Copy only what Tailwind @source + Vite needs
COPY resources/ resources/
COPY vite.config.js postcss.config.js tailwind.config.js ./

# Vendor blade files for Tailwind class scanning (referenced in app.css @source)
COPY --from=php-deps /var/www/html/vendor/laravel/framework/src/Illuminate/Pagination/resources/views/ \
    vendor/laravel/framework/src/Illuminate/Pagination/resources/views/

RUN mkdir -p storage/framework/views

ARG VITE_APP_NAME="Clarity Invoicing"
RUN bun run build

# ========================================
# Stage 3: Clean Application Assembly
# ========================================
FROM serversideup/php:8.5-cli AS app

USER root
WORKDIR /var/www/html

COPY . .
COPY --from=php-deps /var/www/html/vendor vendor/
COPY --from=frontend /build/public/build public/build/

# Remove non-runtime files
RUN rm -rf node_modules tests docker .git .github .agents .claude .gemini \
    docs *.md phpunit.xml phpunit.dusk.xml bun.lock package.json boost.json \
    .env .env.* .editorconfig .gitignore .gitattributes .gitmodules \
    .mcp.json postcss.config.js tailwind.config.js vite.config.js \
    resources/css resources/js

# ========================================
# Production Stage - ServerSideUp FPM + Nginx
# ========================================
FROM serversideup/php:8.5-fpm-nginx AS production

# Switch to root for PHP extension installation
USER root

# Install additional PHP extensions needed for Laravel
RUN install-php-extensions \
    pdo_pgsql \
    pgsql \
    redis \
    gd \
    bcmath \
    intl \
    exif

# Set production environment variables
ENV APP_ENV=production
ENV APP_DEBUG=false
ENV LOG_CHANNEL=stderr
ENV LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter
ENV SESSION_DRIVER=redis
ENV CACHE_DRIVER=redis
ENV QUEUE_CONNECTION=redis
ENV REDIS_HOST=redis
ENV REDIS_PORT=6379

# Copy clean application from app stage
COPY --from=app --chown=www-data:www-data /var/www/html /var/www/html

# Copy H5BP and Laravel nginx configurations
COPY --chown=www-data:www-data docker/production/nginx/h5bp/h5bp/ /etc/nginx/h5bp/
COPY --chown=www-data:www-data docker/production/nginx/h5bp/mime.types /etc/nginx/mime.types

# Copy Laravel customizations
COPY --chown=www-data:www-data docker/production/nginx/laravel-custom/ /etc/nginx/laravel-custom/

# Copy generated configurations
COPY --chown=www-data:www-data docker/production/nginx/generated/nginx.conf /etc/nginx/nginx.conf
COPY --chown=www-data:www-data docker/production/nginx/generated/laravel-site.conf /etc/nginx/conf.d/default.conf

# Copy other production configuration files
COPY --chown=www-data:www-data docker/production/php.ini /usr/local/etc/php/conf.d/99-production.ini
COPY --chown=www-data:www-data docker/production/entrypoint-nginx.sh /usr/local/bin/entrypoint.sh
COPY --chown=www-data:www-data docker/production/supervisor-nginx.conf /etc/supervisor/conf.d/laravel.conf

# Set correct permissions
RUN chmod +x /usr/local/bin/entrypoint.sh && \
    chown -R www-data:www-data /var/www/html && \
    chmod -R 755 /var/www/html && \
    chmod -R 775 /var/www/html/storage /var/www/html/bootstrap/cache

# Switch to root for package installation
USER root

# Install supervisor for background processes
RUN apt-get update && apt-get install -y --no-install-recommends \
    supervisor \
    netcat-openbsd \
    curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Create supervisor log directory
RUN mkdir -p /var/log/supervisor

# Expose ports (80 for Nginx)
EXPOSE 80

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost/up || exit 1

# Set entrypoint
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

# Default command (handled by entrypoint)
CMD ["supervisord", "-c", "/etc/supervisor/conf.d/laravel.conf"]
