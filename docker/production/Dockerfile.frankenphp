# Multi-stage production Dockerfile with FrankenPHP + Octane
# Optimized: separate PHP deps, frontend build (bun), clean app assembly

# ========================================
# Stage 1: PHP Dependencies
# ========================================
FROM serversideup/php:8.5-cli AS php-deps

USER root
WORKDIR /var/www/html

COPY composer.json composer.lock ./

RUN composer install \
    --no-dev \
    --no-interaction \
    --no-progress \
    --no-ansi \
    --no-scripts \
    --optimize-autoloader \
    --classmap-authoritative

# ========================================
# Stage 2: Frontend Build (bun, no Node.js)
# ========================================
FROM oven/bun:1.2-slim AS frontend

WORKDIR /build

COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

# Copy only what Tailwind @source + Vite needs
COPY resources/ resources/
COPY vite.config.js postcss.config.js tailwind.config.js ./

# Vendor blade files for Tailwind class scanning (referenced in app.css @source)
COPY --from=php-deps /var/www/html/vendor/laravel/framework/src/Illuminate/Pagination/resources/views/ \
    vendor/laravel/framework/src/Illuminate/Pagination/resources/views/

RUN mkdir -p storage/framework/views

ARG VITE_APP_NAME="Clarity Invoicing"
RUN bun run build

# ========================================
# Stage 3: Clean Application Assembly
# ========================================
FROM serversideup/php:8.5-cli AS app

USER root
WORKDIR /var/www/html

COPY . .
COPY --from=php-deps /var/www/html/vendor vendor/
COPY --from=frontend /build/public/build public/build/

# Remove non-runtime files
RUN rm -rf node_modules tests docker .git .github .agents .claude .gemini \
    docs *.md phpunit.xml phpunit.dusk.xml bun.lock package.json boost.json \
    .env .env.* .editorconfig .gitignore .gitattributes .gitmodules \
    .mcp.json postcss.config.js tailwind.config.js vite.config.js \
    resources/css resources/js

# ========================================
# FrankenPHP Production Stage
# ========================================
FROM dunglas/frankenphp:latest-php8.5 AS frankenphp

# Install additional PHP extensions
RUN install-php-extensions \
    pcntl \
    pdo_pgsql \
    pgsql \
    redis \
    bcmath \
    exif \
    opcache \
    sockets \
    intl \
    gd

# Set production environment variables
ENV APP_ENV=production
ENV APP_DEBUG=false
ENV OCTANE_SERVER=frankenphp
ENV OCTANE_WORKERS=auto
ENV OCTANE_TASK_WORKERS=auto
ENV OCTANE_MAX_REQUESTS=500
ENV OCTANE_HOST=0.0.0.0
ENV OCTANE_PORT=8000
ENV LOG_CHANNEL=stderr
ENV SESSION_DRIVER=redis
ENV CACHE_DRIVER=redis
ENV QUEUE_CONNECTION=redis

# Set Laravel storage path for consistent file storage (per FrankenPHP docs)
ENV LARAVEL_STORAGE_PATH=/app/storage

# Create non-root user for security
RUN groupadd -g 1000 www && \
    useradd -u 1000 -g www -m -s /bin/bash www

# Set working directory
WORKDIR /app

# Copy clean application from app stage
COPY --from=app --chown=www:www /var/www/html .

# Copy production configuration files
COPY --chown=www:www docker/production/Caddyfile /etc/caddy/Caddyfile
COPY --chown=www:www docker/production/php.ini /usr/local/etc/php/conf.d/99-production.ini
COPY --chown=www:www docker/production/entrypoint.sh /usr/local/bin/entrypoint.sh

# Set correct permissions
RUN chmod +x /usr/local/bin/entrypoint.sh && \
    chown -R www:www /app && \
    chmod -R 755 /app && \
    chmod -R 775 /app/storage /app/bootstrap/cache

# Create supervisor configuration for queue workers
COPY --chown=www:www docker/production/supervisor.conf /etc/supervisor/conf.d/laravel.conf

# Install supervisor and netcat for background processes and health checks
RUN apt-get update && apt-get install -y --no-install-recommends \
    supervisor \
    netcat-openbsd \
    curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /var/run/supervisor /var/log/supervisor \
    && chown -R www:www /var/run/supervisor /var/log/supervisor

# Expose port
EXPOSE 8000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8000/up || exit 1

# Switch to non-root user
USER www

# Set entrypoint
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

# Default command
CMD ["frankenphp", "php-server", "--listen", "0.0.0.0:8000"]
